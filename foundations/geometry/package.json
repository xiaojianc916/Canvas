{
  "name": "@hybrid-canvas/foundations-geometry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/public-api.ts",
  "types": "./src/public-api.ts",
  "exports": {
    ".": "./src/public-api.ts",
    "./point": "./src/point.ts",
    "./size": "./src/size.ts",
    "./rect": "./src/rect.ts",
    "./transform": "./src/transform.ts",
    "./vector": "./src/vector.ts",
    "./angle": "./src/angle.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint src",

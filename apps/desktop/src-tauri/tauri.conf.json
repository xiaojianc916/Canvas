{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hybrid Canvas",
  "version": "0.1.0",
  "identifier": "com.hybrid-canvas.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hybrid Canvas",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 900,
        "height": 640,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": false
      },
      {
        "label": "recovery",
        "title": "Recovery",
        "width": 720,
        "height": 480,
        "center": true,
        "resizable": false,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; object-src 'none'; base-uri 'self'; connect-src 'self' ws: wss: http://localhost:1420 https://localhost:1420;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}

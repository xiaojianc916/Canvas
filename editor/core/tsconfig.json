{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "tsBuildInfoFile": "./node_modules/.cache/typescript/canvas.tsbuildinfo",
    "paths": {
      "@hybrid-canvas/design-system": [
        "../../foundations/design-system/src/public-api.ts"
      ],
      "@hybrid-canvas/kernel": [
        "../../foundations/kernel/src/public-api.ts"
      ],
      "@hybrid-canvas/geometry": [
        "../../foundations/geometry/src/public-api.ts"
      ],
      "@hybrid-canvas/observability": [
        "../../foundations/observability/src/public-api.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
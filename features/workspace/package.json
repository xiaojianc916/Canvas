{
  "name": "@hybrid-canvas/workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/public-api.ts",
      "default": "./src/public-api.ts"
    },
    "./application": {
      "types": "./src/application/public-api.ts",
      "default": "./src/application/public-api.ts"
    },
    "./contracts": {
      "types": "./src/contracts-entry.ts",
      "default": "./src/contracts-entry.ts"
    },
    "./react": {
      "types": "./src/presentation/public-api.ts",
      "default": "./src/presentation/public-api.ts"
    }
  },
  "scripts": {
    "check": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@hybrid-canvas/design-system": "workspace:*",
    "@mynaui/icons-react": "catalog:",
    "motion": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
